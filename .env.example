# Copy to .env for local compose use. Replace every placeholder with deployment-specific values.
POSTGRES_DB=molecule_ranker
POSTGRES_USER=molecule_ranker
POSTGRES_PASSWORD=replace-with-random-postgres-password

# Generate a long random value through your secret manager.
MOLECULE_RANKER_AUTH_SECRET=replace-with-long-random-auth-secret

# Hosted deployments should prefer Postgres. Dev can omit this and use SQLite fallback.
MOLECULE_RANKER_DATABASE_URL=postgresql+psycopg://molecule_ranker:replace-with-random-postgres-password@postgres:5432/molecule_ranker

MOLECULE_RANKER_HOSTED=true
MOLECULE_RANKER_ENABLE_CODEX_WORKER=false
MOLECULE_RANKER_CODEX_WORKER_CONCURRENCY=1
MOLECULE_RANKER_CODEX_JOB_TIMEOUT_SECONDS=300
MOLECULE_RANKER_CODEX_ARTIFACT_CONTEXT_MAX_BYTES=1000000

# Do not put Codex or OpenAI credentials in this file. Use an operator-approved
# credential mechanism mounted at runtime, and keep it outside project artifacts.
